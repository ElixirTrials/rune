{
  "name": "rune GPU Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "runArgs": ["--gpus", "all", "--shm-size=8g", "--network=host"],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.gpuAcceleration": "off"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:${containerEnv:HOME}/.local/bin:/usr/local/cuda/bin",
    "LD_LIBRARY_PATH": "/usr/local/cuda/lib64:${containerEnv:LD_LIBRARY_PATH}",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "UV_LINK_MODE": "copy"
  }
}
